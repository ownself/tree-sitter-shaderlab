{
  "grammars": [
    {
      "name": "shaderlab",
      "camelcase": "ShaderLab",
      "scope": "source.shaderlab",
      "path": ".",
      "file-types": [
        "shader"
      ]
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for Unity ShaderLab with HLSL injection support",
    "links": {
      "repository": "https://github.com/ownself/tree-sitter-shaderlab"
    }
  },
  "bindings": {
    "c": true,
    "node": true,
    "rust": true
  }
}